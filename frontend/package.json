{
  "name": "flight-review-frontend",
  "version": "0.0.1",
  "private": true,
	"scripts": {
		"dev": "vite dev",
		"predev": "npm run generate:api",
		"generate:api": "orval --config orval.config.ts",
		"prebuild": "node scripts/sync-duckdb-assets.mjs && npm run generate:api",
