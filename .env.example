# Required: create a key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=replace-me

# Used when an uploader does not explicitly select a model.
OPENROUTER_DEFAULT_MODEL=openrouter/auto
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME="PX4 Flight Review"
OPENROUTER_SITE_URL=http://localhost:3000

# Shared pilot access. Use a long, private passphrase.
ACCESS_PASSWORD=replace-with-a-long-password
# Local HTTP needs false; Railway enables secure cookies automatically.
ACCESS_COOKIE_SECURE=false

# Optional map/geocoding support.
PUBLIC_MAPBOX_TOKEN=
MAPBOX_ACCESS_TOKEN=

# Storage defaults to the local /data volume. For Railway Buckets or another
# S3-compatible provider, uncomment these and use its generated credentials.
# STORAGE_URL=s3://bucket-name/flight-review
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_ENDPOINT=https://storage.railway.app
# S3_URL_STYLE=virtual

# Optional host ports and logging.
WEB_PORT=3000
RUST_LOG=info
SERVER_FEATURES=s3

# Idempotently import the five pinned public PX4 examples on startup.
SEED_LOGS=true
SEED_LOGS_PUBLIC=true
